{
  "name": "goagent",
  "version": "0.4.18",
  "description": "Agentic AI teacher for Go / Weiqi / Baduk, powered by KataGo and multimodal LLMs.",
  "main": "out/main/index.js",
  "type": "module",
  "author": "haoc",
  "license": "MIT",
  "homepage": "https://github.com/wimi321/GoAgent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wimi321/GoAgent.git"
  },
  "bugs": {
    "url": "https://github.com/wimi321/GoAgent/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "node scripts/start_dev_app.mjs",
    "dev:vite": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preview": "node scripts/start_dev_app.mjs --skip-build",
    "lint": "pnpm typecheck",
    "test": "node --test tests/*.test.mjs",
    "check": "pnpm test && pnpm typecheck && pnpm build",
    "eval:teacher": "node scripts/eval_teaching_accuracy.mjs",
    "eval:claims": "node scripts/eval_teacher_claims.mjs",
    "eval:quality-gate": "node scripts/eval_teacher_quality_gate.mjs",
    "check:knowledge-sources": "node scripts/check_knowledge_sources.mjs",
    "eval:knowledge-coverage": "node scripts/eval_knowledge_coverage.mjs",
    "eval:shape-recognition": "node scripts/eval_shape_recognition.mjs",
    "eval:move-range": "node scripts/eval_move_range.mjs",
    "eval:vision-evidence": "node scripts/eval_vision_evidence.mjs",
    "eval:katago-trace": "node scripts/eval_katago_trace.mjs",
    "eval:engine-silver": "node scripts/eval_engine_silver.mjs",
    "eval:real-teaching": "node scripts/eval_real_teaching.mjs",
    "eval:real-teaching:strict": "node scripts/eval_real_teaching.mjs --strict",
    "eval:teacher-style": "node scripts/eval_teacher_style.mjs",
    "eval:teacher-session": "node scripts/eval_teacher_session.mjs",
    "eval:tts-provider-policy": "node scripts/eval_tts_provider_policy.mjs",
    "check:teacher-artifact": "node --test tests/teacher-artifact-contract.test.mjs",
    "prepare:tts-assets": "node scripts/prepare_tts_assets.mjs",
    "check:tts-assets": "node scripts/check_tts_assets.mjs",
    "smoke:tts": "node scripts/smoke_tts.mjs",
    "website:install": "pnpm --dir website install",
    "website:build": "pnpm --dir website build",
    "website:dev": "pnpm --dir website dev",
    "website:check": "pnpm --dir website build",
    "check:website": "node scripts/check_website.mjs",
    "capture:ui-gallery": "node scripts/capture_ui_gallery.mjs",
    "smoke:release-artifacts": "node scripts/release_artifact_smoke.mjs",
    "smoke:windows-packaged": "node scripts/smoke_windows_packaged_app.mjs",
    "check:teacher-quality": "pnpm build && pnpm eval:teacher && pnpm eval:claims && pnpm eval:quality-gate && pnpm check:knowledge-sources && pnpm eval:knowledge-coverage && pnpm eval:shape-recognition && pnpm eval:move-range && pnpm eval:vision-evidence && pnpm eval:katago-trace && pnpm eval:engine-silver && pnpm eval:teacher-style && pnpm eval:teacher-session && pnpm eval:tts-provider-policy && pnpm check:teacher-artifact",
    "package": "pnpm dist",
    "dist": "pnpm build && electron-builder",
    "check:deep-teacher-quality": "pnpm check:teacher-quality && pnpm eval:real-teaching:strict",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "dist:win": "pnpm build && electron-builder --win --publish never",
    "dist:linux": "pnpm build && electron-builder --linux --publish never",
    "dist:local:mac": "pnpm prepare:zhizi-b28 && pnpm dist:mac",
    "dist:local:win": "pnpm prepare:zhizi-b28 && pnpm dist:win",
    "dist:local:linux": "pnpm prepare:zhizi-b28 && pnpm dist:linux",
    "postinstall": "electron-builder install-app-deps",
    "prepare:python": "python3 -m pip install -r scripts/requirements.txt",
    "prepare:katago-assets": "node scripts/prepare_katago_assets.mjs",
    "prepare:zhizi-b28": "node scripts/download_zhizi_b28.mjs",
    "check:katago-assets": "node scripts/check_katago_assets.mjs --mode=dev",
    "check:katago-assets:release": "node scripts/check_katago_assets.mjs --mode=release",
    "check:no-lite-release-assets": "node scripts/check_no_lite_release_assets.mjs",
    "check:nvidia-release-assets": "node scripts/check_nvidia_release_assets.mjs",
    "check:release-notes-i18n": "node scripts/check_release_notes_i18n.mjs",
    "check:release-quality": "pnpm check:teacher-quality && pnpm check:no-lite-release-assets && pnpm check:nvidia-release-assets && pnpm check:release-notes-i18n && pnpm check:tts-assets && pnpm smoke:tts && pnpm smoke:release-artifacts",
    "check:p0-beta": "node scripts/p0_beta_acceptance.mjs",
    "check:artifacts": "node scripts/package_artifact_smoke.mjs --mode=dev",
    "smoke:teacher-llm": "pnpm build && node scripts/teacher_llm_smoke.mjs",
    "smoke:teacher-llm:real": "pnpm build && node scripts/teacher_llm_real_smoke.mjs",
    "smoke:zhizi-remote": "node scripts/smoke_zhizi_remote.mjs",
    "rc:check": "node scripts/p0_release_candidate_check.mjs --mode=dev",
    "rc:artifacts": "node scripts/verify_release_artifacts.mjs --mode=dev",
    "rc:evidence": "node scripts/collect_release_evidence.mjs --mode=dev"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "kokoro-js": "^1.2.1",
    "openai": "^6.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io-client": "^4.8.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "build": {
    "appId": "com.goagent.desktop",
    "productName": "GoAgent",
    "icon": "assets/icon",
    "directories": {
      "output": "release/${version}"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "scripts/**/*",
      "data/knowledge/**/*",
      "!data/katago/**/*",
      "!data/tts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/katago",
        "to": "data/katago",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data/tts",
        "to": "data/tts",
        "filter": [
          "**/*",
          "!kokoro/zh-CN/onnx/model_int8.onnx"
        ]
      }
    ],
    "asarUnpack": [],
    "asar": true,
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}",
      "files": [
        "out/**/*",
        "scripts/**/*",
        "data/knowledge/**/*",
        "!data/katago/**/*",
        "!data/tts/**/*",
        "assets/**/*",
        "package.json",
        "!**/node_modules/onnxruntime-node/bin/napi-v3/darwin/**",
        "!**/node_modules/onnxruntime-node/bin/napi-v3/linux/**",
        "!**/node_modules/onnxruntime-node/bin/napi-v3/win32/arm64/**",
        "!**/node_modules/@img/sharp-darwin-*/*",
        "!**/node_modules/@img/sharp-libvips-darwin-*/*",
        "!**/node_modules/@img/sharp-linux-*/*",
        "!**/node_modules/@img/sharp-libvips-linux-*/*"
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Education"
    },
    "publish": {
      "provider": "github",
      "owner": "wimi321",
      "repo": "GoAgent"
    }
  }
}
