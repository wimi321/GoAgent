      faq: 'FAQ',
      changelog: 'อัปเดต'
    },
    cta: 'ดาวน์โหลด',
    footer: 'ครู AI หมากล้อมแบบโอเพนซอร์สและฟรี KataGo ให้หลักฐาน ส่วน AI อธิบายให้เข้าใจง่าย',
    community: 'ชุมชน QQ: 1030632742',
    privacy: 'ความเป็นส่วนตัว',
    copyright: 'GoAgent contributors'
  },
  vi: {
    skip: 'Chuyển tới nội dung',
    brandSub: 'AI agent cờ vây',
