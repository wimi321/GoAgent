---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://goagent.top/images/go-tools-hero.jpg" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#faf9f5" />
    <meta name="color-scheme" content="light" />
    {alternateItems.map((item) => <link rel="alternate" hreflang={item.lang} href={item.href} />)}
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#content">{copy.skip}</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="brand-cluster" aria-label="Site brands">
          <a class="brand brand-primary" href={homeHref} aria-label="LizzieYzy Next home">
            <img src="/logo.svg" alt="" width="36" height="36" />
            <span>{copy.brand}</span>
            <small>{copy.brandSub}</small>
          </a>
          <a class="brand brand-secondary" href={goAgentUrl} aria-label="GoAgent GitHub">
            <img src="/logo.svg" alt="" width="30" height="30" />
            <span>GoAgent</span>
            <small>{copy.goAgentSub}</small>
          </a>
        </div>
        <nav aria-label="Primary">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <div class="header-actions">
          <div class="language-switcher" aria-label="Language">
            {languageItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
          <a class="header-cta" href={sectionHref('download')}>{copy.cta}</a>
        </div>
      </header>
      <main id="content">
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>{copy.brand}</strong>
          <p>{copy.footer}</p>
          <p class="community-line">{copy.community}</p>
        </div>
        <div class="footer-links">
          <a href={lizzieUrl}>LizzieYzy Next GitHub</a>
          <a href={lizzieReleases}>LizzieYzy Next Releases</a>
          <a href={goAgentUrl}>GoAgent GitHub</a>
          <a href={goAgentReleases}>GoAgent Releases</a>
          <a href={goAgentIssues}>Issues</a>
          <a href={localizedPath(siteLang, 'privacy')}>{copy.privacy}</a>
        </div>
        <nav class="footer-resources" aria-label="Resources">
          {resourceItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <p class="copyright">Copyright © {new Date().getFullYear()} {copy.copyright}.</p>
      </footer>
    </div>
  </body>
</html>
