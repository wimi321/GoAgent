---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
  lang?: string
  jsonLd?: Record<string, unknown>
}

const {
  title = 'GoAgent - 开源免费的专业围棋 AI 老师',
  description = 'GoAgent 是开源免费的专业围棋智能体：KataGo 负责事实，多模态 LLM 负责讲解，帮助棋友看懂关键手。',
  canonical = new URL(Astro.url.pathname, 'https://goagent.top').toString(),
  lang = 'zh-CN',
  jsonLd
} = Astro.props

const githubUrl = 'https://github.com/wimi321/GoAgent'
const releasesUrl = `${githubUrl}/releases`
const issuesUrl = `${githubUrl}/issues`

const homeByLang = {
  'zh-CN': '/',
  'zh-Hant': '/zh-hant',
  en: '/en',
  ja: '/ja',
  ko: '/ko',
  th: '/th',
  vi: '/vi'
} as const

const copyByLang = {
  'zh-CN': {
    skip: '跳到主要内容',
    brandSub: '围棋智能体',
    nav: {
      home: '首页',
      download: '下载',
      docs: '文档',
      privacy: '隐私',
      faq: 'FAQ',
      changelog: '更新'
    },
    cta: '下载',
    footer: '开源免费的围棋智能体。KataGo 给证据，AI 老师讲清楚。',
    community: 'QQ 交流群：1030632742',
    privacy: '隐私',
    copyright: 'GoAgent contributors'
  },
  'zh-Hant': {
    skip: '跳到主要內容',
    brandSub: '圍棋智能體',
    nav: {
      home: '首頁',
      download: '下載',
      docs: '文檔',
      privacy: '隱私',
      faq: 'FAQ',
      changelog: '更新'
    },
    cta: '下載',
    footer: '開源免費的圍棋智能體。KataGo 給證據，AI 老師講清楚。',
    community: 'QQ 交流群：1030632742',
    privacy: '隱私',
    copyright: 'GoAgent contributors'
  },
  en: {
    skip: 'Skip to content',
    brandSub: 'Go AI agent',
    nav: {
      home: 'Home',
      download: 'Download',
      docs: 'Guide',
      privacy: 'Privacy',
      faq: 'FAQ',
      changelog: 'Updates'
    },
    cta: 'Download',
    footer: 'Open-source and free Go AI teacher. KataGo gives evidence. AI explains clearly.',
    community: 'QQ community: 1030632742',
    privacy: 'Privacy',
    copyright: 'GoAgent contributors'
  },
  ja: {
    skip: '本文へ移動',
    brandSub: '囲碁 AI エージェント',
    nav: {
      home: 'ホーム',
      download: 'ダウンロード',
      docs: 'ガイド',
      privacy: 'プライバシー',
      faq: 'FAQ',
      changelog: '更新'
    },
    cta: 'ダウンロード',
    footer: 'オープンソースで無料の囲碁 AI 先生。KataGo が根拠を出し、AI がわかりやすく説明します。',
    community: 'QQ コミュニティ：1030632742',
    privacy: 'プライバシー',
    copyright: 'GoAgent contributors'
  },
  ko: {
    skip: '본문으로 이동',
    brandSub: '바둑 AI 에이전트',
    nav: {
      home: '홈',
      download: '다운로드',
      docs: '가이드',
      privacy: '개인정보',
      faq: 'FAQ',
      changelog: '업데이트'
    },
    cta: '다운로드',
    footer: '오픈소스 무료 바둑 AI 선생님. KataGo가 근거를 제시하고 AI가 쉽게 설명합니다.',
    community: 'QQ 커뮤니티: 1030632742',
    privacy: '개인정보',
    copyright: 'GoAgent contributors'
  },
  th: {
    skip: 'ไปยังเนื้อหา',
