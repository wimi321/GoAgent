      docs: 'Hướng dẫn',
      privacy: 'Riêng tư',
      faq: 'FAQ',
      changelog: 'Cập nhật'
    },
    cta: 'Tải xuống',
    footer: 'Giáo viên AI cờ vây mã nguồn mở và miễn phí. KataGo đưa bằng chứng, AI giải thích rõ ràng.',
    community: 'Cộng đồng QQ: 1030632742',
    privacy: 'Riêng tư',
    copyright: 'GoAgent contributors'
  }
} as const

type SiteLang = keyof typeof copyByLang
const siteLang = (lang in copyByLang ? lang : 'zh-CN') as SiteLang
const copy = copyByLang[siteLang]
const homeHref = homeByLang[siteLang]
const isChineseMain = siteLang === 'zh-CN'

const navItems = isChineseMain
  ? [
      { href: '/', label: copy.nav.home },
      { href: '/download', label: copy.nav.download },
      { href: '/docs', label: copy.nav.docs },
      { href: '/privacy', label: copy.nav.privacy },
      { href: '/faq', label: copy.nav.faq },
      { href: '/changelog', label: copy.nav.changelog }
    ]
  : [
      { href: homeHref, label: copy.nav.home },
      { href: `${homeHref}#download`, label: copy.nav.download },
      { href: `${homeHref}#how`, label: copy.nav.docs },
      { href: '/privacy', label: copy.nav.privacy },
      { href: '/faq', label: copy.nav.faq },
      { href: '/changelog', label: copy.nav.changelog }
    ]

const languageItems = [
  { href: '/', label: '简' },
  { href: '/zh-hant', label: '繁' },
  { href: '/en', label: 'EN' },
  { href: '/ja', label: '日' },
  { href: '/ko', label: '한' },
  { href: '/th', label: 'TH' },
  { href: '/vi', label: 'VI' }
]
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://goagent.top/logo.svg" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f7f8f5" />
    <meta name="color-scheme" content="light" />
    <link rel="alternate" hreflang="zh-CN" href="https://goagent.top/" />
    <link rel="alternate" hreflang="zh-Hant" href="https://goagent.top/zh-hant" />
    <link rel="alternate" hreflang="en" href="https://goagent.top/en" />
    <link rel="alternate" hreflang="ja" href="https://goagent.top/ja" />
    <link rel="alternate" hreflang="ko" href="https://goagent.top/ko" />
    <link rel="alternate" hreflang="th" href="https://goagent.top/th" />
    <link rel="alternate" hreflang="vi" href="https://goagent.top/vi" />
    <link rel="alternate" hreflang="x-default" href="https://goagent.top/" />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#content">{copy.skip}</a>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={homeHref} aria-label="GoAgent home">
          <img src="/logo.svg" alt="" width="36" height="36" />
          <span>GoAgent</span>
          <small>{copy.brandSub}</small>
        </a>
        <nav aria-label={copy.nav.home}>
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <div class="header-actions">
          <div class="language-switcher" aria-label="Language">
            {languageItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
          <a class="header-cta" href={releasesUrl}>{copy.cta}</a>
        </div>
      </header>
      <main id="content">
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>GoAgent</strong>
          <p>{copy.footer}</p>
          <p class="community-line">{copy.community}</p>
        </div>
        <div class="footer-links">
          <a href={githubUrl}>GitHub</a>
          <a href={releasesUrl}>Releases</a>
          <a href={issuesUrl}>Issues</a>
          <a href="/privacy">{copy.privacy}</a>
          <a href={`${githubUrl}/blob/main/LICENSE`}>License MIT</a>
        </div>
        <p class="copyright">Copyright © {new Date().getFullYear()} {copy.copyright}.</p>
      </footer>
    </div>
  </body>
</html>
