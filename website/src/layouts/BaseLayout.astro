---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
  lang?: string
  pageKey?: 'home' | 'download' | 'docs' | 'privacy' | 'faq' | 'changelog'
  jsonLd?: Record<string, unknown>
}

const {
  title = 'GoAgent - 围棋 AI 工具箱',
  description = 'goagent.top 是 GoAgent 和 LizzieYzy Next 共用官网：一款把关键手讲清楚，一款把整盘复盘看清楚。',
  canonical = new URL(Astro.url.pathname, 'https://goagent.top').toString(),
  lang = 'zh-CN',
  pageKey = 'home',
  jsonLd
} = Astro.props

const goAgentUrl = 'https://github.com/wimi321/GoAgent'
const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const goAgentIssues = `${goAgentUrl}/issues`
const lizzieUrl = 'https://github.com/wimi321/lizzieyzy-next'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'

const homeByLang = {
  'zh-CN': '/',
  'zh-Hant': '/zh-hant',
  en: '/en',
  ja: '/ja',
  ko: '/ko',
  th: '/th',
  vi: '/vi'
} as const

const localeSlugs = {
  'zh-CN': '',
  'zh-Hant': 'zh-hant',
  en: 'en',
  ja: 'ja',
  ko: 'ko',
  th: 'th',
  vi: 'vi'
} as const

function localizedPath(locale: keyof typeof localeSlugs, key: NonNullable<Props['pageKey']>) {
  const localePrefix = localeSlugs[locale]
  const pageSegment = key === 'home' ? '' : key
  if (!localePrefix && !pageSegment) return '/'
  if (!localePrefix) return `/${pageSegment}`
  return pageSegment ? `/${localePrefix}/${pageSegment}` : `/${localePrefix}`
}

const copyByLang = {
  'zh-CN': {
    skip: '跳到主要内容',
    brandSub: '围棋 AI 工具箱',
    nav: { products: '产品', workflow: '工作流', download: '下载', docs: '文档', faq: 'FAQ' },
    cta: '免费下载',
    footer: 'GoAgent 把关键手讲清楚；LizzieYzy Next 把整盘复盘看清楚。两个开源桌面工具，共用一个官网。',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: '隐私',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  'zh-Hant': {
    skip: '跳到主要內容',
    brandSub: '圍棋 AI 工具箱',
    nav: { products: '產品', workflow: '工作流', download: '下載', docs: '文檔', faq: 'FAQ' },
    cta: '免費下載',
    footer: 'GoAgent 把關鍵手講清楚；LizzieYzy Next 把整盤復盤看清楚。兩個開源桌面工具，共用一個官網。',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: '隱私',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  en: {
    skip: 'Skip to content',
    brandSub: 'Go AI toolkit',
    nav: { products: 'Products', workflow: 'Workflow', download: 'Download', docs: 'Guide', faq: 'FAQ' },
    cta: 'Download free',
    footer: 'GoAgent explains key moves clearly; LizzieYzy Next makes the whole-game review easier to read. Two open-source desktop tools, one website.',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: 'Privacy',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  ja: {
    skip: '本文へ移動',
    brandSub: '囲碁 AI ツールキット',
    nav: { products: 'プロダクト', workflow: '流れ', download: 'ダウンロード', docs: 'ガイド', faq: 'FAQ' },
    cta: '無料ダウンロード',
    footer: 'GoAgent は重要な一手を説明し、LizzieYzy Next は一局全体を読みやすくします。',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: 'プライバシー',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  ko: {
    skip: '본문으로 이동',
    brandSub: '바둑 AI 툴킷',
    nav: { products: '제품', workflow: '흐름', download: '다운로드', docs: '가이드', faq: 'FAQ' },
    cta: '무료 다운로드',
    footer: 'GoAgent는 핵심 수를 설명하고, LizzieYzy Next는 전체 판 복기를 보기 쉽게 만듭니다.',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: '개인정보',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  th: {
    skip: 'ไปยังเนื้อหา',
    brandSub: 'ชุดเครื่องมือ AI หมากล้อม',
    nav: { products: 'ผลิตภัณฑ์', workflow: 'เวิร์กโฟลว์', download: 'ดาวน์โหลด', docs: 'คู่มือ', faq: 'FAQ' },
    cta: 'ดาวน์โหลดฟรี',
    footer: 'GoAgent อธิบายหมากสำคัญ ส่วน LizzieYzy Next ช่วยอ่านภาพรวมทั้งเกมให้ชัดขึ้น',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: 'ความเป็นส่วนตัว',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  },
  vi: {
    skip: 'Chuyển tới nội dung',
    brandSub: 'Bộ công cụ AI cờ vây',
    nav: { products: 'Sản phẩm', workflow: 'Quy trình', download: 'Tải xuống', docs: 'Hướng dẫn', faq: 'FAQ' },
    cta: 'Tải miễn phí',
    footer: 'GoAgent giải thích nước quan trọng; LizzieYzy Next giúp đọc toàn bộ ván rõ hơn.',
    community: 'GoAgent QQ 1030632742 · LizzieYzy Next QQ 299419120',
    privacy: 'Riêng tư',
    copyright: 'GoAgent and LizzieYzy Next contributors'
  }
} as const

type SiteLang = keyof typeof copyByLang
const siteLang = (lang in copyByLang ? lang : 'zh-CN') as SiteLang
const copy = copyByLang[siteLang]
const homeHref = homeByLang[siteLang]
const sectionHref = (section: string) => `${homeHref === '/' ? '/' : homeHref}#${section}`

const navItems = [
  { href: sectionHref('products'), label: copy.nav.products },
  { href: sectionHref('workflow'), label: copy.nav.workflow },
  { href: sectionHref('download'), label: copy.nav.download },
  { href: localizedPath(siteLang, 'docs'), label: copy.nav.docs },
  { href: localizedPath(siteLang, 'faq'), label: copy.nav.faq }
]

const languageItems = [
  { href: localizedPath('zh-CN', pageKey), label: '简' },
  { href: localizedPath('zh-Hant', pageKey), label: '繁' },
  { href: localizedPath('en', pageKey), label: 'EN' },
  { href: localizedPath('ja', pageKey), label: '日' },
  { href: localizedPath('ko', pageKey), label: '한' },
  { href: localizedPath('th', pageKey), label: 'TH' },
  { href: localizedPath('vi', pageKey), label: 'VI' }
]

const alternateItems = [
  { lang: 'zh-CN', href: `https://goagent.top${localizedPath('zh-CN', pageKey)}` },
  { lang: 'zh-Hant', href: `https://goagent.top${localizedPath('zh-Hant', pageKey)}` },
  { lang: 'en', href: `https://goagent.top${localizedPath('en', pageKey)}` },
  { lang: 'ja', href: `https://goagent.top${localizedPath('ja', pageKey)}` },
  { lang: 'ko', href: `https://goagent.top${localizedPath('ko', pageKey)}` },
  { lang: 'th', href: `https://goagent.top${localizedPath('th', pageKey)}` },
  { lang: 'vi', href: `https://goagent.top${localizedPath('vi', pageKey)}` },
  { lang: 'x-default', href: `https://goagent.top${localizedPath('zh-CN', pageKey)}` }
]
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://goagent.top/images/go-tools-hero.jpg" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#faf9f5" />
    <meta name="color-scheme" content="light" />
    {alternateItems.map((item) => <link rel="alternate" hreflang={item.lang} href={item.href} />)}
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#content">{copy.skip}</a>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={homeHref} aria-label="GoAgent home">
          <img src="/logo.svg" alt="" width="36" height="36" />
          <span>GoAgent</span>
          <small>{copy.brandSub}</small>
        </a>
        <nav aria-label="Primary">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <div class="header-actions">
          <div class="language-switcher" aria-label="Language">
            {languageItems.map((item) => <a href={item.href}>{item.label}</a>)}
          </div>
          <a class="header-cta" href={sectionHref('download')}>{copy.cta}</a>
        </div>
      </header>
      <main id="content">
        <slot />
      </main>
      <footer class="site-footer">
        <div>
          <strong>GoAgent</strong>
          <p>{copy.footer}</p>
          <p class="community-line">{copy.community}</p>
        </div>
        <div class="footer-links">
          <a href={goAgentUrl}>GoAgent GitHub</a>
          <a href={lizzieUrl}>LizzieYzy Next GitHub</a>
          <a href={goAgentReleases}>GoAgent Releases</a>
          <a href={lizzieReleases}>LizzieYzy Next Releases</a>
          <a href={goAgentIssues}>Issues</a>
          <a href={localizedPath(siteLang, 'privacy')}>{copy.privacy}</a>
        </div>
        <p class="copyright">Copyright © {new Date().getFullYear()} {copy.copyright}.</p>
      </footer>
    </div>
  </body>
</html>
