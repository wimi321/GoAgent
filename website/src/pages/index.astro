---
import BaseLayout from '../layouts/BaseLayout.astro'

const releasesUrl = 'https://github.com/wimi321/GoAgent/releases'
const githubUrl = 'https://github.com/wimi321/GoAgent'

const boardMargin = 48
const boardSpan = 664
const step = boardSpan / 18
const lines = Array.from({ length: 19 }, (_, index) => boardMargin + index * step)
const starPoints = [3, 9, 15].flatMap((x) => [3, 9, 15].map((y) => ({ x, y })))
const stones = [
  { x: 3, y: 3, color: 'black' },
  { x: 15, y: 3, color: 'white' },
  { x: 15, y: 15, color: 'black' },
  { x: 3, y: 15, color: 'white' },
  { x: 9, y: 10, color: 'black', last: true },
  { x: 10, y: 9, color: 'white' },
  { x: 11, y: 11, color: 'black' }
]
const candidates = [
  { x: 12, y: 9, rank: 1, winrate: '58%', visits: '12k', score: '+3.1' },
  { x: 8, y: 11, rank: 2, winrate: '55%', visits: '8k', score: '+1.7' },
  { x: 11, y: 8, rank: 3, winrate: '53%', visits: '4k', score: '+0.9' }
]
const toPoint = (value: number) => boardMargin + value * step

const valueCards = [
  ['开源', '代码公开在 GitHub，路线透明，欢迎一起改进。'],
  ['免费', '安装包免费下载，普通棋友也能直接试用。'],
  ['专业', 'KataGo 给证据，AI 老师把关键手讲清楚。']
]

const features = [
  ['当前手讲解', '点击一手棋，看到候选点、胜率差、PV 和老师解释。'],
  ['区间复盘', '只看一段关键手，快速找出中盘战和转折点。'],
  ['棋形识别', '识别常见定式、死活、手筋和形状，不硬套名字。'],
  ['学生适配', '按水平、年龄和老师风格调整讲解深度。'],
  ['开源透明', '项目在 GitHub 公开，问题和路线都可追踪。'],
  ['桌面应用', 'Windows 和 macOS 优先，适合长期复盘学习。']
]

const downloads = [
  ['Windows x64 标准版', '普通 Windows 用户首选'],
  ['Windows x64 NVIDIA 版', 'NVIDIA 显卡用户'],
  ['macOS Apple Silicon', 'M 系列 Mac'],
  ['macOS Intel', 'Intel Mac']
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GoAgent',
  alternateName: '围棋智能体',
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Windows, macOS',
  description: 'GoAgent 是开源免费的专业围棋 AI 老师，结合 KataGo 和多模态 LLM 帮助用户看懂关键手。',
  url: 'https://goagent.top/',
  codeRepository: githubUrl,
  license: `${githubUrl}/blob/main/LICENSE`,
  downloadUrl: releasesUrl,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD'
  }
}
---
<BaseLayout
  title="GoAgent - 开源免费的专业围棋 AI 老师"
  description="GoAgent 是开源免费的专业围棋 AI 老师：导入棋谱，结合 KataGo 和多模态 LLM，把关键手讲成普通用户听得懂的话。"
  jsonLd={jsonLd}
>
  <section class="hero hero-premium">
    <div class="hero-copy">
      <p class="eyebrow">开源 · 免费 · 专业</p>
      <h1><span>让 AI 老师</span><span>把棋讲明白</span></h1>
      <p class="subtitle">导入棋谱，看懂关键手。</p>
      <p class="lead">
        GoAgent 是一款免费的围棋智能体。它会看棋盘、看候选点、看变化，把“这手为什么亏”“好点好在哪里”“下一次该先看哪里”讲成人能听懂的话。
      </p>
      <div class="button-row">
        <a class="button primary" href={releasesUrl}>免费下载</a>
        <a class="button" href={githubUrl}>查看开源代码</a>
        <a class="button subtle" href="/docs">快速开始</a>
      </div>
      <div class="hero-note">
        <span>Windows / macOS</span>
        <span>MIT License</span>
        <span>QQ 1030632742</span>
      </div>
    </div>

    <aside class="hero-visual hero-device" aria-label="GoAgent product preview">
      <div class="device-chrome">
        <div class="traffic" aria-hidden="true"><span></span><span></span><span></span></div>
        <span>GoAgent · current move</span>
      </div>
      <div class="device-body">
        <div class="board-panel">
          <svg class="go-board-svg" viewBox="0 0 760 760" role="img" aria-label="标准 19 路围棋棋盘预览">
            <defs>
              <linearGradient id="boardGlow" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0%" stop-color="#f3cc86" />
                <stop offset="55%" stop-color="#e0a85d" />
                <stop offset="100%" stop-color="#c98b45" />
              </linearGradient>
              <radialGradient id="blackStone" cx="32%" cy="26%" r="74%">
                <stop offset="0%" stop-color="#86837b" />
                <stop offset="40%" stop-color="#262521" />
                <stop offset="100%" stop-color="#060605" />
              </radialGradient>
              <radialGradient id="whiteStone" cx="32%" cy="24%" r="78%">
                <stop offset="0%" stop-color="#ffffff" />
                <stop offset="58%" stop-color="#eee8dc" />
                <stop offset="100%" stop-color="#b9ac98" />
              </radialGradient>
              <filter id="stoneShadow" x="-30%" y="-20%" width="160%" height="170%">
                <feDropShadow dx="0" dy="9" stdDeviation="8" flood-color="#5d3b16" flood-opacity="0.28" />
              </filter>
              <filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="16" stdDeviation="18" flood-color="#644217" flood-opacity="0.18" />
              </filter>
            </defs>
            <rect x="18" y="18" width="724" height="724" rx="54" fill="url(#boardGlow)" filter="url(#softShadow)" />
            <rect x="18" y="18" width="724" height="724" rx="54" fill="none" stroke="rgba(89, 58, 24, .18)" />
            {lines.map((pos) => (
              <>
                <line x1={boardMargin} y1={pos} x2={boardMargin + boardSpan} y2={pos} class="board-line" />
                <line x1={pos} y1={boardMargin} x2={pos} y2={boardMargin + boardSpan} class="board-line" />
              </>
            ))}
            {starPoints.map((point) => (
              <circle cx={toPoint(point.x)} cy={toPoint(point.y)} r="5.6" class="star-point" />
            ))}
            {stones.map((stone) => (
              <g class={`stone-svg ${stone.color}`} filter="url(#stoneShadow)">
                <circle cx={toPoint(stone.x)} cy={toPoint(stone.y)} r="17.8" fill={stone.color === 'black' ? 'url(#blackStone)' : 'url(#whiteStone)'} />
                {stone.last && <circle cx={toPoint(stone.x)} cy={toPoint(stone.y)} r="6.5" class="last-mark" />}
              </g>
            ))}
            {candidates.map((candidate) => (
              <g class={`candidate-svg rank-${candidate.rank}`} transform={`translate(${toPoint(candidate.x)} ${toPoint(candidate.y)})`}>
                <circle r="22.5" />
                <text class="candidate-rank" y="-7">{candidate.rank}</text>
                <text class="candidate-main" y="7">{candidate.winrate}</text>
                <text class="candidate-sub" y="18">{candidate.visits} · {candidate.score}</text>
              </g>
            ))}
          </svg>
          <div class="board-caption">
            <strong>第 128 手</strong>
            <span>黑棋候选点 · 胜率差 6.2%</span>
          </div>
        </div>

        <div class="teacher-panel">
          <div class="tool-trace">
            <span>读取棋谱</span>
            <span>KataGo 分析</span>
            <span>知识匹配</span>
          </div>
          <div class="teacher-message">
            <p>这手的想法是对的：黑棋想压住上边。</p>
            <p>但一选更专业，因为它先看住白棋反击点，同时保留右边的后续。实战亏的不只是这一下，而是让白棋把节奏拿回去了。</p>
          </div>
          <div class="composer-preview">
            <span>问问 AI 老师：这手为什么不是一选？</span>
            <strong>↵</strong>
          </div>
        </div>
      </div>
    </aside>
  </section>

  <section class="value-section">
    <div class="grid three">
      {valueCards.map(([title, text]) => (
        <article class="value-card">
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-head centered">
      <p class="eyebrow">运作方式</p>
      <h2>三步看懂一盘棋</h2>
      <p>KataGo 负责事实，AI 老师负责讲解，质量检查负责减少乱讲。</p>
    </div>
    <div class="grid three workflow">
      <article class="card">
        <h3>导入棋谱</h3>
        <p>导入 SGF 或选择棋谱，定位当前手、关键区间和双方信息。</p>
      </article>
      <article class="card">
        <h3>找出关键手</h3>
        <p>胜率曲线、候选点、目差、PV 和问题手列表一起帮你缩小复盘范围。</p>
      </article>
      <article class="card">
        <h3>听懂讲解</h3>
        <p>AI 老师结合棋盘、KataGo 和知识库，说人话，不把复盘写成机器报告。</p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <p class="eyebrow">产品</p>
        <h2>做给普通棋友用，也给认真学棋的人用。</h2>
      </div>
      <p>不用被一整盘胜率图淹没。GoAgent 会把关键手、候选点和老师解释放在同一个工作台里。</p>
    </div>
    <div class="grid three">
      {features.map(([title, text]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="feature-panel premium-panel">
      <div>
        <p class="eyebrow">老师风格</p>
        <h2>常规定式少讲，中盘战多讲。</h2>
        <p>
          真正的老师不会每手都长篇大论。正常定式简单点到；出现分支就讲选择条件；进入中盘战、攻杀和转换，才展开说目的、应手、变化和实战损失。
        </p>
      </div>
      <ul class="feature-list">
        <li>常见定式正常进行时，只讲一句方向。</li>
        <li>局部分支出现时，列关键变化，不硬套名称。</li>
        <li>明显亏损时，解释实战想法为什么能理解、又亏在哪里。</li>
        <li>输出里提到手数和坐标时，可以回到棋盘查看。</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-head">
      <div>
        <p class="eyebrow">下载</p>
        <h2>免费下载桌面版</h2>
      </div>
      <p>安装包放在 GitHub Releases。官网保持轻量，下载前可查看 SHA256SUMS.txt。</p>
    </div>
    <div class="grid four">
      {downloads.map(([title, audience]) => (
        <article class="download-card">
          <h3>{title}</h3>
          <p>{audience}</p>
          <a class="button" href={releasesUrl}>前往下载</a>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
