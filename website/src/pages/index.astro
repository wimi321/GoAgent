---
import BaseLayout from '../layouts/BaseLayout.astro'

const goAgentGithub = 'https://github.com/wimi321/GoAgent'
const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const lizzieGithub = 'https://github.com/wimi321/lizzieyzy-next'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'
const lizzieBaidu = 'https://pan.baidu.com/s/1wthaL8YwGMxy_u0U7Mabpw?pwd=3i8w'

const products = [
  {
    title: 'LizzieYzy Next',
    label: '首推 · 专业复盘工作台',
    image: '/images/lizzieyzy-next-workbench.jpg',
    alt: 'LizzieYzy Next 全盘分析工作台',
    summary: '大多数棋友先装这个。打开棋谱，就能看胜率、目差和关键失误，快速知道一盘棋哪里下坏了。',
    points: ['导入棋谱就能看', '找关键失误', '看胜率和目差', 'Windows / macOS / Linux'],
    primary: '下载 LizzieYzy Next',
    secondary: '查看代码',
    release: lizzieBaidu,
    repo: lizzieGithub,
    featured: true
  },
  {
    title: 'GoAgent',
    label: '实验项目 · 围棋智能体',
    image: '/images/goagent-workbench.jpg',
    alt: 'GoAgent 围棋讲解工作台',
    summary: '想试 AI 讲棋时再用。它是实验功能，会尝试把局面和 KataGo 结果讲成更容易听懂的话。',
    points: ['实验功能', 'AI 讲棋', '适合尝鲜', 'Windows / macOS'],
    primary: '试用 GoAgent',
    secondary: '查看代码',
    release: goAgentReleases,
    repo: goAgentGithub,
    featured: false
  }
]

const workflow = [
  ['先下载 LizzieYzy Next', '先装这个，大多数棋友日常复盘都够用。'],
  ['打开棋谱看问题', '看胜率、目差和关键失误，快速知道这盘棋哪里下坏了。'],
  ['想尝鲜再试 GoAgent', '想让 AI 用自然语言讲棋时，再试 GoAgent 这个实验功能。']
]

const downloads = [
  {
    title: '推荐：LizzieYzy Next 百度网盘',
    text: '国内用户优先用百度网盘下载，大多数棋友下载后就能开始复盘。',
    href: lizzieBaidu,
    note: '国内优先',
    cta: '百度网盘下载',
    label: '推荐先点这个',
    icon: 'cloud',
    featured: true
  },
  {
    title: '备用：LizzieYzy Next GitHub 下载',
    text: 'GitHub 是备用下载入口。页面是英文也没关系，找最新安装包下载。',
    href: lizzieReleases,
    note: '备用下载',
    cta: '从 GitHub 下载',
    label: '',
    icon: 'github',
    featured: false
  },
  {
    title: '想尝鲜：GoAgent',
    text: 'GoAgent 是实验围棋智能体，适合想试 AI 讲棋的用户。只想稳定复盘，先不用管它。',
    href: goAgentReleases,
    note: '实验功能',
    cta: '试用 GoAgent',
    label: '',
    icon: 'agent',
    featured: false
  }
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LizzieYzy Next',
  alternateName: '专业围棋复盘工作台',
  url: 'https://goagent.top/',
  description: 'LizzieYzy Next 是面向棋友的专业 KataGo 复盘工作台；GoAgent 是实验中的围棋智能体。',
  hasPart: [
    {
      '@type': 'SoftwareApplication',
      name: 'LizzieYzy Next',
      applicationCategory: 'GameApplication',
      operatingSystem: 'Windows, macOS, Linux',
      url: lizzieGithub,
      downloadUrl: [lizzieBaidu, lizzieReleases],
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    },
    {
      '@type': 'SoftwareApplication',
      name: 'GoAgent',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Windows, macOS',
      url: goAgentGithub,
      downloadUrl: goAgentReleases,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    }
  ]
}
---
<BaseLayout
  title="LizzieYzy Next - 专业围棋复盘工作台"
  description="LizzieYzy Next 是首推的专业 KataGo 复盘工作台，适合棋友快速看清整盘走势；GoAgent 是实验中的围棋智能体。"
  pageKey="home"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="hero-copy">
      <h1>
        <span>想复盘围棋，</span>
        <span>先下载 <strong>LizzieYzy Next</strong></span>
      </h1>
      <p class="lead">
        大多数棋友直接安装 LizzieYzy Next，用它看胜率、目差和关键失误；想尝试 AI 讲棋时，再试 GoAgent。
      </p>
      <div class="button-row hero-actions" aria-label="下载入口">
        <a class="button primary" href={lizzieBaidu}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 4v10" />
            <path d="m8 10 4 4 4-4" />
            <path d="M5 18h14" />
            <path d="M7 15.5A5 5 0 0 1 8.4 6a6.5 6.5 0 0 1 11.1 4.4A3.9 3.9 0 0 1 18 18H7" />
          </svg>
          <span>国内下载（百度网盘）</span>
        </a>
        <a class="button" href={lizzieReleases}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.5a9.6 9.6 0 0 0-3 18.8c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 2.9.8.1-.7.4-1.1.7-1.4-2.3-.3-4.6-1.2-4.6-5a4 4 0 0 1 1.1-2.8c-.1-.3-.5-1.3.1-2.7 0 0 .8-.3 2.8 1a9.8 9.8 0 0 1 5.1 0c2-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7a4 4 0 0 1 1.1 2.8c0 3.9-2.4 4.7-4.6 5 .4.3.7.9.7 1.8v2.7c0 .3.2.6.7.5A9.6 9.6 0 0 0 12 2.5Z" />
          </svg>
          <span>备用：从 GitHub 下载</span>
        </a>
        <a class="button subtle" href={goAgentReleases}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 11h8a4 4 0 0 1 4 4v1a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-1a4 4 0 0 1 4-4Z" />
            <path d="M12 11V6" />
            <path d="M9 6h6" />
            <path d="M9 15.5h.1" />
            <path d="M15 15.5h.1" />
          </svg>
          <span>想尝鲜：试用 GoAgent</span>
        </a>
      </div>
      <p class="hero-download-note">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3 19 6v5c0 4.5-2.8 8-7 10-4.2-2-7-5.5-7-10V6l7-3Z" />
          <path d="m8.8 12 2.1 2.1 4.4-4.7" />
        </svg>
        <span>国内用户优先用百度网盘下载。</span>
      </p>
    </div>
  </section>

  <section class="home-proof-strip" aria-label="官网要点">
    <div class="home-proof-inner">
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
            <path d="M16 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
            <path d="M4 20a4 4 0 0 1 8 0" />
            <path d="M12 20a4 4 0 0 1 8 0" />
          </svg>
        </span>
        <p>大多数人先装这个</p>
      </div>
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 5h16v11H4Z" />
            <path d="M9 20h6" />
            <path d="M12 16v4" />
          </svg>
        </span>
        <p>支持 Windows / macOS / Linux</p>
      </div>
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M9 18h6" />
            <path d="M10 22h4" />
            <path d="M8.5 14.5A6 6 0 1 1 15.5 14.5c-.8.7-1.2 1.4-1.4 2.5H9.9c-.2-1.1-.6-1.8-1.4-2.5Z" />
            <path d="M12 2v2" />
            <path d="m4.9 4.9 1.4 1.4" />
            <path d="m19.1 4.9-1.4 1.4" />
          </svg>
        </span>
        <p>GoAgent 是实验功能</p>
      </div>
    </div>
  </section>

  <section id="products" class="section-block product-section">
    <div class="section-head centered">
      <h2>不知道怎么选？先装 LizzieYzy Next</h2>
      <p>先解决复盘问题，再考虑 AI 讲棋。GoAgent 是实验功能，想尝鲜时再试。</p>
    </div>
    <div class="product-grid">
      {products.map((product) => (
        <article class={`product-panel ${product.featured ? 'featured' : ''}`}>
          <img src={product.image} alt={product.alt} width="1536" height="1152" loading="eager" decoding="async" />
          <div class="product-copy">
            <p class="product-label">{product.label}</p>
            <h3>{product.title}</h3>
            <p>{product.summary}</p>
            <ul>
              {product.points.map((point) => <li>{point}</li>)}
            </ul>
            <div class="button-row compact">
              <a class="button primary" href={product.release}>{product.primary}</a>
              <a class="button subtle" href={product.repo}>{product.secondary}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow" class="section-block workflow-section">
    <div class="section-head">
      <div>
        <h2>普通棋友的正确打开方式</h2>
        <p>先完成一次清晰的全盘复盘，再决定要不要加上 AI 讲解。</p>
      </div>
    </div>
    <div class="workflow-line">
      {workflow.map(([title, text], index) => (
        <article class="workflow-step">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="download" class="section-block download-section">
    <div class="section-head centered">
      <h2>下载顺序很简单</h2>
      <p>国内用户优先用百度网盘下载；GitHub 是备用入口；GoAgent 是实验功能，想试 AI 讲棋再下载。</p>
    </div>
    <div class="download-list">
      {downloads.map((download) => (
        <article class={`download-row ${download.featured ? 'featured' : ''}`}>
          <span class={`download-icon ${download.icon}`} aria-hidden="true">
            {download.icon === 'cloud' && (
              <svg viewBox="0 0 48 48" role="img">
                <path d="M17.4 35.4H14a9 9 0 0 1-1.1-18 12.8 12.8 0 0 1 24.5 4.3A7 7 0 0 1 36 35.4h-5.4" />
                <path d="M24 19.8v18" />
                <path d="m17.8 31.8 6.2 6.2 6.2-6.2" />
              </svg>
            )}
            {download.icon === 'github' && (
              <svg viewBox="0 0 48 48" role="img">
                <path d="M24 7.6a16.4 16.4 0 0 0-5.2 32c.8.1 1.1-.3 1.1-.8v-3c-4.5 1-5.5-1.9-5.5-1.9-.7-1.9-1.8-2.4-1.8-2.4-1.5-1 .1-1 .1-1 1.6.1 2.5 1.7 2.5 1.7 1.5 2.5 3.8 1.8 4.7 1.4.1-1.1.6-1.8 1-2.2-3.6-.4-7.4-1.8-7.4-8a6.2 6.2 0 0 1 1.7-4.4c-.2-.4-.7-2.1.2-4.3 0 0 1.3-.4 4.5 1.7a15.3 15.3 0 0 1 8.2 0c3.1-2.1 4.5-1.7 4.5-1.7.9 2.2.3 3.9.2 4.3a6.2 6.2 0 0 1 1.7 4.4c0 6.2-3.8 7.6-7.4 8 .6.5 1.1 1.5 1.1 3v4.4c0 .5.3.9 1.1.8A16.4 16.4 0 0 0 24 7.6Z" />
              </svg>
            )}
            {download.icon === 'agent' && (
              <svg viewBox="0 0 48 48" role="img">
                <path d="M17 20h14a7 7 0 0 1 7 7v3a7 7 0 0 1-7 7H17a7 7 0 0 1-7-7v-3a7 7 0 0 1 7-7Z" />
                <path d="M24 20v-7" />
                <path d="M20 13h8" />
                <path d="M18.5 28.5h.1" />
                <path d="M29.5 28.5h.1" />
              </svg>
            )}
          </span>
          <div>
            {download.label && <p class="product-label">{download.label}</p>}
            <h3>{download.title}</h3>
            <p>{download.text}</p>
            <small>{download.note}</small>
          </div>
          <a class={`button ${download.featured ? 'primary' : 'subtle'}`} href={download.href}>{download.cta}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
