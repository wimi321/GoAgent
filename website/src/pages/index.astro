---
import BaseLayout from '../layouts/BaseLayout.astro'

const goAgentGithub = 'https://github.com/wimi321/GoAgent'
const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const lizzieGithub = 'https://github.com/wimi321/lizzieyzy-next'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'

const products = [
  {
    title: 'GoAgent',
    label: 'AI 围棋老师',
    image: '/images/goagent-workbench.jpg',
    alt: 'GoAgent 围棋讲解工作台',
    summary: '适合想把一手棋听明白的人。它把棋盘、KataGo 证据、知识库和 AI 老师问答放在一起，帮你理解关键手。',
    points: ['当前手讲解', 'KataGo 证据链', 'AI 老师问答', 'Windows / macOS'],
    primary: '下载 GoAgent',
    secondary: '查看代码',
    release: goAgentReleases,
    repo: goAgentGithub
  },
  {
    title: 'LizzieYzy Next',
    label: '专业复盘工作台',
    image: '/images/lizzieyzy-next-workbench.jpg',
    alt: 'LizzieYzy Next 全盘分析工作台',
    summary: '适合想快速看完整盘走势的人。它维护 LizzieYzy 的 KataGo GUI 体验，强化野狐抓谱、快速全盘分析和胜率概览。',
    points: ['野狐昵称抓谱', '快速全盘分析', '胜率图与底部概览', 'Windows / macOS / Linux'],
    primary: '下载 LizzieYzy Next',
    secondary: '查看代码',
    release: lizzieReleases,
    repo: lizzieGithub
  }
]

const workflow = [
  ['导入棋谱', '从本地 SGF、野狐公开棋谱或已有棋谱库开始，不需要先理解引擎参数。'],
  ['看清走势', '用 LizzieYzy Next 先扫完整盘胜率、目差和问题手分布，快速定位转折点。'],
  ['听懂关键手', '回到 GoAgent 问当前手：为什么亏、好点在哪里、下一盘先看什么。']
]

const downloads = [
  ['GoAgent Releases', '开源免费的 AI 围棋老师，优先下载 Windows 或 macOS 桌面版。', goAgentReleases, 'GoAgent QQ 1030632742'],
  ['LizzieYzy Next Releases', '持续维护的 KataGo 复盘 GUI，提供 Windows、macOS、Linux 多平台发布包。', lizzieReleases, 'LizzieYzy Next QQ 299419120']
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'GoAgent',
  alternateName: '围棋 AI 工具箱',
  url: 'https://goagent.top/',
  description: 'goagent.top 是 GoAgent 和 LizzieYzy Next 共用的围棋 AI 工具官网。',
  hasPart: [
    {
      '@type': 'SoftwareApplication',
      name: 'GoAgent',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Windows, macOS',
      url: goAgentGithub,
      downloadUrl: goAgentReleases,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    },
    {
      '@type': 'SoftwareApplication',
      name: 'LizzieYzy Next',
      applicationCategory: 'GameApplication',
      operatingSystem: 'Windows, macOS, Linux',
      url: lizzieGithub,
      downloadUrl: lizzieReleases,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    }
  ]
}
---
<BaseLayout
  title="GoAgent - 围棋 AI 工具箱"
  description="goagent.top 是 GoAgent 和 LizzieYzy Next 共用官网：一款把关键手讲清楚，一款把整盘复盘看清楚。"
  pageKey="home"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="hero-copy">
      <h1>一站找到好用的围棋 AI 工具</h1>
      <p class="lead">
        GoAgent 负责把棋讲明白；LizzieYzy Next 负责把整盘复盘看清楚。两款开源桌面工具，共用一个官网。
      </p>
      <div class="button-row">
        <a class="button primary" href={goAgentReleases}>下载 GoAgent</a>
        <a class="button" href={lizzieReleases}>下载 LizzieYzy Next</a>
        <a class="button subtle" href="#products">先看区别</a>
      </div>
      <div class="trust-row" aria-label="官网要点">
        <span>开源免费</span>
        <span>KataGo 分析</span>
        <span>Windows / macOS / Linux</span>
      </div>
    </div>
    <figure class="hero-art">
      <img src="/images/go-tools-hero.jpg" alt="围棋棋盘与两款 AI 复盘工具界面" width="1600" height="914" loading="eager" decoding="async" />
    </figure>
  </section>

  <section id="products" class="section-block product-section">
    <div class="section-head centered">
      <h2>两款工具，相辅相成</h2>
      <p>想让 AI 老师讲清楚，用 GoAgent；想快速看完整盘走势，用 LizzieYzy Next。</p>
    </div>
    <div class="product-grid">
      {products.map((product) => (
        <article class="product-panel">
          <img src={product.image} alt={product.alt} width="1536" height="1152" loading="lazy" decoding="async" />
          <div class="product-copy">
            <p class="product-label">{product.label}</p>
            <h3>{product.title}</h3>
            <p>{product.summary}</p>
            <ul>
              {product.points.map((point) => <li>{point}</li>)}
            </ul>
            <div class="button-row compact">
              <a class="button primary" href={product.release}>{product.primary}</a>
              <a class="button subtle" href={product.repo}>{product.secondary}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow" class="section-block workflow-section">
    <div class="section-head">
      <div>
        <h2>从棋谱到复盘，只走三步</h2>
        <p>普通用户不需要先懂引擎参数：先下载、导入棋谱，再看图和解释。</p>
      </div>
    </div>
    <div class="workflow-line">
      {workflow.map(([title, text], index) => (
        <article class="workflow-step">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="download" class="section-block download-section">
    <div class="section-head centered">
      <h2>免费下载</h2>
      <p>官网保持轻量，安装包统一放在 GitHub Releases，方便校验、回滚和追踪版本。</p>
    </div>
    <div class="download-list">
      {downloads.map(([title, text, href, note]) => (
        <article class="download-row">
          <div>
            <h3>{title}</h3>
            <p>{text}</p>
            <small>{note}</small>
          </div>
          <a class="button primary" href={href}>打开 Releases</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
