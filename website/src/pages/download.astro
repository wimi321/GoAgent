---
import BaseLayout from '../layouts/BaseLayout.astro'

const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'

const tools = [
  {
    audience: '想听懂关键手',
    title: 'GoAgent',
    text: '开源免费的 AI 围棋老师。适合当前手讲解、KataGo 证据解释、AI 老师问答。',
    platforms: ['Windows', 'macOS'],
    href: goAgentReleases,
    qq: 'QQ 1030632742'
  },
  {
    audience: '想快速复盘整盘',
    title: 'LizzieYzy Next',
    text: '持续维护的 KataGo 复盘 GUI。适合野狐昵称抓谱、快速全盘分析、胜率图和底部概览。',
    platforms: ['Windows', 'macOS', 'Linux'],
    href: lizzieReleases,
    qq: 'QQ 299419120'
  }
]
---
<BaseLayout title="下载 GoAgent 与 LizzieYzy Next" description="从 GitHub Releases 下载 GoAgent 和 LizzieYzy Next 的桌面发布包。" pageKey="download">
  <section class="page-hero">
    <h1>免费下载</h1>
    <p class="lead">官网不托管大型安装包。两个项目都从 GitHub Releases 下载，方便校验、回滚和版本追踪。</p>
  </section>
  <section class="content-stack">
    <div class="grid two">
      {tools.map((tool) => (
        <article class="download-card">
          <p class="product-label">{tool.audience}</p>
          <h2>{tool.title}</h2>
          <p>{tool.text}</p>
          <div class="download-meta">
            {tool.platforms.map((platform) => <span>{platform}</span>)}
            <span>GitHub Releases</span>
            <span>SHA256</span>
          </div>
          <p>{tool.qq}</p>
          <a class="button primary" href={tool.href}>打开 Releases</a>
        </article>
      ))}
    </div>
    <article class="notice">
      <h2>校验下载文件</h2>
      <p>下载前先确认项目名、版本号和文件名。下载后建议对照 release 中的校验文件，尤其是从镜像或第三方链接下载时。</p>
      <ul>
        <li>Windows 可使用 PowerShell 的 Get-FileHash。</li>
        <li>macOS 可使用 shasum -a 256。</li>
        <li>如果文件名、版本号或校验值不一致，请回到对应项目的 GitHub Releases 重新下载。</li>
      </ul>
    </article>
  </section>
</BaseLayout>
