export function getStaticPaths() {
  const locales = ['zh-hant', 'en', 'ja', 'ko', 'th', 'vi'] as const
  const pages = ['download', 'docs', 'privacy', 'faq', 'changelog'] as const
  return locales.flatMap((locale) => pages.map((page) => ({ params: { locale, page } })))
}

const locale = Astro.params.locale as LocaleKey
const page = Astro.params.page as PageKey
const sourceData = localized[locale][page]
const data = (page === 'download' ? simpleDownloads[locale] : ((friendlyPages as any)[locale]?.[page] ?? sourceData)) as any
const meta = localeMeta[locale]
const canonical = `https://goagent.top/${locale}/${page}`
const jsonLd = page === 'faq'
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.items.map(([question, answer]) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: { '@type': 'Answer', text: answer }
      }))
    }
  : undefined
---
<BaseLayout title={data.title} description={data.description} lang={meta.lang} canonical={canonical} pageKey={page} jsonLd={jsonLd}>
  {page === 'download' && (
    <>
      <section class="page-hero">
        <p class="eyebrow">{data.eyebrow}</p>
        <h1>{data.h1}</h1>
        <p class="lead">{data.lead}</p>
        <div class="button-row">
          <a class="button primary" href={lizzieBaiduUrl}>{data.tools[0][4]}</a>
          <a class="button" href={lizzieReleasesUrl}>{data.tools[1][4]}</a>
        </div>
      </section>
      <section class="content-stack">
        <div class="download-list">
          {data.tools.map(([audience, title, text, href, cta, badge, featured]) => (
            <article class={`download-row ${featured ? 'featured' : ''}`}>
              <div>
              <p class="eyebrow">{audience}</p>
              <h3>{title}</h3>
              <p>{text}</p>
              <div class="download-meta">
                <span>{badge}</span>
                <span>{title.includes('GoAgent') ? 'GoAgent' : 'LizzieYzy Next'}</span>
              </div>
              </div>
              <a class={`button ${featured ? 'primary' : 'subtle'}`} href={href}>{cta}</a>
            </article>
          ))}
        </div>
        <article class="notice">
          <h2>{data.noticeTitle}</h2>
          <ul>{data.noticeItems.map((item) => <li>{item}</li>)}</ul>
        </article>
      </section>
    </>
  )}

  {page === 'docs' && (
    <>
      <section class="page-hero">
        <p class="eyebrow">{data.eyebrow}</p>
        <h1>{data.h1}</h1>
        <p class="lead">{data.lead}</p>
      </section>
      <section class="content-stack">
        {data.steps.map(([title, text], index) => (
          <article class="doc-card step-card">
            <span class="step-index">{index + 1}</span>
            <div>
              <h2>{title}</h2>
              <p>{text}</p>
            </div>
          </article>
        ))}
        <article class="notice">
          <h2>{data.qualityTitle}</h2>
          <ul>{data.qualityItems.map((item) => <li>{item}</li>)}</ul>
        </article>
      </section>
    </>
  )}

  {page === 'privacy' && (
    <>
      <section class="page-hero">
        <p class="eyebrow">{data.eyebrow}</p>
        <h1>{data.h1}</h1>
        <p class="lead">{data.lead}</p>
      </section>
      <section class="content-stack">
        {data.sections.map(([title, items]) => (
          <article class="privacy-panel">
            <h2>{title}</h2>
            <ul>{items.map((item) => <li>{item}</li>)}</ul>
          </article>
        ))}
      </section>
    </>
  )}

  {page === 'faq' && (
    <>
      <section class="page-hero">
        <p class="eyebrow">{data.eyebrow}</p>
        <h1>{data.h1}</h1>
        <p class="lead">{data.lead}</p>
      </section>
      <section class="content-stack faq-list">
        {data.items.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </section>
    </>
  )}

  {page === 'changelog' && (
    <>
      <section class="page-hero">
        <p class="eyebrow">{data.eyebrow}</p>
        <h1>{data.h1}</h1>
        <p class="lead">{data.lead}</p>
      </section>
      <section class="content-stack">
        {data.entries.map(([title, text]) => (
          <article class="doc-card">
            <h2>{title}</h2>
            <p>{text}</p>
          </article>
        ))}
      </section>
    </>
  )}
</BaseLayout>
