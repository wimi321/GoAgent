    featureTitle: 'Dễ dùng cho người chơi thường, hữu ích cho học nghiêm túc',
    productEyebrow: 'Sản phẩm',
    featureBody: 'GoAgent đặt nước quan trọng, nước gợi ý và lời giải thích của giáo viên trong cùng một không gian.',
    features: [
      ['Giải thích nước hiện tại', 'Bấm một nước để xem gợi ý, mất tỉ lệ thắng, PV và lời giải thích.'],
      ['Ôn tập theo đoạn', 'Chọn một đoạn để nhanh chóng tìm điểm xoay chuyển.'],
      ['Nhận diện hình cờ', 'Nhận diện joseki, sống chết, tesuji và shape mà không kết luận quá mức.']
    ],
    teacherEyebrow: 'Phong cách giáo viên',
    teacherTitle: 'Joseki bình thường nói ngắn, trung bàn nói kỹ',
    teacherBody: 'Một giáo viên tốt không nói dài mọi nước. Joseki bình thường chỉ cần nhắc hướng; nhánh biến hóa thì nêu lựa chọn; chiến đấu hoặc mất lớn thì giải thích mục đích, đáp trả, biến hóa và kết quả.',
    teacherPoints: ['Joseki bình thường nói ngắn gọn.', 'Khi có nhánh, nêu biến hóa quan trọng.', 'Giải thích vì sao ý tưởng thực chiến hợp lý nhưng vẫn mất giá trị.'],
    downloadEyebrow: 'Tải xuống',
    downloadTitle: 'Tải ứng dụng desktop miễn phí',
    downloadBody: 'Bộ cài nằm trên GitHub Releases. Hãy kiểm tra SHA256SUMS.txt trước khi cài.',
    downloadCards: [['Windows x64 Standard', 'Phù hợp với hầu hết người dùng Windows'], ['Windows x64 NVIDIA', 'Dành cho người dùng GPU NVIDIA'], ['macOS Apple Silicon', 'Dành cho Mac chip M'], ['macOS Intel', 'Dành cho Intel Mac']]
  }
}

export function getStaticPaths() {
  return ['zh-hant', 'en', 'ja', 'ko', 'th', 'vi'].map((locale) => ({ params: { locale } }))
}

const locale = Astro.params.locale as keyof typeof locales
const page = locales[locale] ?? locales.en
---
<BaseLayout title={page.title} description={page.description} lang={page.lang} canonical={`https://goagent.top/${locale}`}>
  <section class="page-hero localized-hero">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>GoAgent</h1>
    <p class="subtitle">{page.headline}</p>
    <p class="lead">{page.body}</p>
    <div class="button-row">
      <a class="button primary" href={releasesUrl}>{page.primary}</a>
      <a class="button" href={githubUrl}>{page.secondary}</a>
      <a class="button subtle" href="#how">{page.guide}</a>
    </div>
  </section>

  <section class="value-section">
    <div class="grid three">
      {page.valueCards.map(([title, text]) => (
        <article class="value-card">
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="how">
    <div class="section-head centered">
      <p class="eyebrow">{page.workflowEyebrow}</p>
      <h2>{page.workflowTitle}</h2>
      <p>{page.workflowBody}</p>
    </div>
    <div class="grid three workflow">
      {page.workflow.map(([title, text]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="features">
    <div class="section-head">
      <div>
        <p class="eyebrow">{page.productEyebrow}</p>
        <h2>{page.featureTitle}</h2>
      </div>
      <p>{page.featureBody}</p>
    </div>
    <div class="grid three">
      {page.features.map(([title, text]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="feature-panel premium-panel">
      <div>
        <p class="eyebrow">{page.teacherEyebrow}</p>
        <h2>{page.teacherTitle}</h2>
        <p>{page.teacherBody}</p>
      </div>
      <ul class="feature-list">
        {page.teacherPoints.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section id="download">
    <div class="section-head">
      <div>
        <p class="eyebrow">{page.downloadEyebrow}</p>
        <h2>{page.downloadTitle}</h2>
      </div>
      <p>{page.downloadBody}</p>
    </div>
    <div class="grid four">
      {page.downloadCards.map(([title, audience]) => (
        <article class="download-card">
          <h3>{title}</h3>
          <p>{audience}</p>
          <a class="button" href={releasesUrl}>{page.primary}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
