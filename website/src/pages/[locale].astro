export function getStaticPaths() {
  return ['zh-hant', 'en', 'ja', 'ko', 'th', 'vi'].map((locale) => ({ params: { locale } }))
}

const locale = Astro.params.locale as keyof typeof locales
const page = locales[locale] ?? locales.en
const home = homeCopy[locale] ?? homeCopy.en
---
<BaseLayout title={home.title} description={home.description} lang={page.lang} canonical={`https://goagent.top/${locale}`} pageKey="home">
  <section class="home-hero">
    <div class="hero-copy">
      <h1>
        <span>{home.line1}</span>
        <span>{home.line2Before} <strong>LizzieYzy Next</strong>{home.line2After}</span>
      </h1>
      <p class="lead">{home.lead}</p>
      <div class="button-row hero-actions" aria-label="Download choices">
        <a class="button primary" href={lizzieBaidu}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 4v10" />
            <path d="m8 10 4 4 4-4" />
            <path d="M5 18h14" />
            <path d="M7 15.5A5 5 0 0 1 8.4 6a6.5 6.5 0 0 1 11.1 4.4A3.9 3.9 0 0 1 18 18H7" />
          </svg>
          <span>{home.baiduCta}</span>
        </a>
        <a class="button" href={lizzieReleases}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.5a9.6 9.6 0 0 0-3 18.8c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 2.9.8.1-.7.4-1.1.7-1.4-2.3-.3-4.6-1.2-4.6-5a4 4 0 0 1 1.1-2.8c-.1-.3-.5-1.3.1-2.7 0 0 .8-.3 2.8 1a9.8 9.8 0 0 1 5.1 0c2-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7a4 4 0 0 1 1.1 2.8c0 3.9-2.4 4.7-4.6 5 .4.3.7.9.7 1.8v2.7c0 .3.2.6.7.5A9.6 9.6 0 0 0 12 2.5Z" />
          </svg>
          <span>{home.githubCta}</span>
        </a>
        <a class="button subtle" href={goAgentReleases}>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 11h8a4 4 0 0 1 4 4v1a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-1a4 4 0 0 1 4-4Z" />
            <path d="M12 11V6" />
            <path d="M9 6h6" />
            <path d="M9 15.5h.1" />
            <path d="M15 15.5h.1" />
          </svg>
          <span>{home.goAgentCta}</span>
        </a>
      </div>
      <p class="hero-download-note">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3 19 6v5c0 4.5-2.8 8-7 10-4.2-2-7-5.5-7-10V6l7-3Z" />
          <path d="m8.8 12 2.1 2.1 4.4-4.7" />
        </svg>
        <span>{home.note}</span>
      </p>
    </div>
  </section>

  <section class="home-proof-strip" aria-label="Website highlights">
    <div class="home-proof-inner">
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
            <path d="M16 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
            <path d="M4 20a4 4 0 0 1 8 0" />
            <path d="M12 20a4 4 0 0 1 8 0" />
          </svg>
        </span>
        <p>{home.proofs[0]}</p>
      </div>
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 5h16v11H4Z" />
            <path d="M9 20h6" />
            <path d="M12 16v4" />
          </svg>
        </span>
        <p>{home.proofs[1]}</p>
      </div>
      <div class="home-proof-item">
        <span aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M9 18h6" />
            <path d="M10 22h4" />
            <path d="M8.5 14.5A6 6 0 1 1 15.5 14.5c-.8.7-1.2 1.4-1.4 2.5H9.9c-.2-1.1-.6-1.8-1.4-2.5Z" />
            <path d="M12 2v2" />
            <path d="m4.9 4.9 1.4 1.4" />
            <path d="m19.1 4.9-1.4 1.4" />
          </svg>
        </span>
        <p>{home.proofs[2]}</p>
      </div>
    </div>
  </section>

  <section id="products" class="section-block product-section">
    <div class="section-head centered">
      <h2>{page.productsTitle}</h2>
      <p>{page.productsLead}</p>
    </div>
    <div class="product-grid">
      {page.products.map((product) => (
        <article class={`product-panel ${product.featured ? 'featured' : ''}`}>
          <img src={product.image} alt={product.alt} width="1536" height="1152" loading="eager" decoding="async" />
          <div class="product-copy">
            <p class="product-label">{product.label}</p>
            <h3>{product.title}</h3>
            <p>{product.summary}</p>
            <ul>{product.points.map((point) => <li>{point}</li>)}</ul>
            <div class="button-row compact">
              <a class="button primary" href={product.release}>{product.primary}</a>
              <a class="button subtle" href={product.repo}>{product.secondary}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow" class="section-block workflow-section">
    <div class="section-head">
      <div>
        <h2>{page.workflowTitle}</h2>
        <p>{page.workflowLead}</p>
      </div>
    </div>
    <div class="workflow-line">
      {page.workflow.map(([title, text], index) => (
        <article class="workflow-step">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="download" class="section-block download-section">
    <div class="section-head centered">
      <h2>{page.downloadTitle}</h2>
      <p>{home.downloadLead}</p>
    </div>
    <div class="download-list">
      <article class="download-row featured">
        <div>
          <h3>LizzieYzy Next</h3>
          <p>{home.proofs[0]} · {home.proofs[1]}</p>
        </div>
        <div class="button-row compact">
          <a class="button primary" href={lizzieBaidu}>{home.baiduCta}</a>
          <a class="button subtle" href={lizzieReleases}>{home.githubCta}</a>
        </div>
      </article>
      <article class="download-row">
        <div>
          <h3>GoAgent</h3>
          <p>{home.proofs[2]} · GoAgent QQ 1030632742</p>
        </div>
        <a class="button subtle" href={goAgentReleases}>{home.goAgentCta}</a>
      </article>
    </div>
  </section>
</BaseLayout>
