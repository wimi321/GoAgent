---
import BaseLayout from '../layouts/BaseLayout.astro'

const docs = [
  ['第一步：先下载 LizzieYzy Next', '大多数棋友先装这个就够了。国内用户优先用百度网盘下载；GitHub 是备用入口。'],
  ['第二步：选对你的电脑系统', 'Windows 用户下载 Windows 包，Mac 用户下载 macOS 包，Linux 用户下载 Linux 包。先找最新版本里的安装包，不用读完整英文页面。'],
  ['第三步：打开棋谱开始复盘', '安装后导入 SGF 棋谱，先看胜率、目差和关键失误。不要一开始研究太多设置，先把一盘棋看明白。'],
  ['第四步：先看三个重点', '先看哪几手胜率掉得多，再看目差变化，最后看 KataGo 推荐的候选点。普通复盘先抓这三件事就够用。'],
  ['第五步：想听 AI 讲棋，再试 GoAgent', 'GoAgent 是实验功能，适合想尝试 AI 自然语言讲解的人。只想稳定复盘，不用一开始就安装 GoAgent。'],
  ['第六步：下载或安装遇到问题', '下载不顺时可以换另一个入口或网络。Windows 提示安全拦截时，请确认文件来自官网链接后再继续。'],
  ['第七步：隐私怎么理解', 'LizzieYzy Next 和 GoAgent 都是桌面工具，棋谱复盘优先在你的电脑上完成。GoAgent 只有在你自己配置 AI 服务并发起讲解时，才会把必要内容发给你配置的服务。'],
  ['第八步：需要帮助时', '先看常见问题；还解决不了，可以去 GitHub Issues，或加入 QQ 群 1030632742 / 299419120 交流。']
]
---
<BaseLayout title="使用指南 - LizzieYzy Next 和 GoAgent" description="面向普通棋友的使用指南：先下载 LizzieYzy Next，打开棋谱复盘；想尝试 AI 讲棋时再试 GoAgent。" pageKey="docs">
  <section class="page-hero">
    <h1>使用指南</h1>
    <p class="lead">不用研究术语。先下载 LizzieYzy Next，打开棋谱，看胜率、目差和关键失误；想尝试 AI 讲棋时，再下载 GoAgent。</p>
  </section>
  <section class="content-stack">
    {docs.map(([title, text], index) => (
      <article class="doc-card step-card">
        <span class="step-index">{index + 1}</span>
        <div>
          <h2>{title}</h2>
          <p>{text}</p>
        </div>
      </article>
    ))}
    <article class="notice">
      <h2>记住一句话</h2>
      <ul>
        <li>只想复盘：先用 LizzieYzy Next。</li>
        <li>国内用户：优先用百度网盘下载。</li>
        <li>想尝试 AI 讲棋：再试 GoAgent。</li>
      </ul>
    </article>
  </section>
</BaseLayout>
